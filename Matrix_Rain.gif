    @keyframes fall30 { 0%{transform:translateY(-200px)} 100%{transform:translateY(220px)} }

    .s1  { animation: fall1  2.1s linear infinite; animation-delay: 0.0s; }
    .s2  { animation: fall2  2.5s linear infinite; animation-delay: 0.3s; }
    .s3  { animation: fall3  1.9s linear infinite; animation-delay: 0.7s; }
    .s4  { animation: fall4  2.3s linear infinite; animation-delay: 0.1s; }
    .s5  { animation: fall5  2.0s linear infinite; animation-delay: 0.5s; }
    .s6  { animation: fall6  2.7s linear infinite; animation-delay: 0.9s; }
    .s7  { animation: fall7  1.8s linear infinite; animation-delay: 0.2s; }
    .s8  { animation: fall8  2.4s linear infinite; animation-delay: 0.6s; }
    .s9  { animation: fall9  2.2s linear infinite; animation-delay: 0.4s; }
    .s10 { animation: fall10 1.7s linear infinite; animation-delay: 0.8s; }
    .s11 { animation: fall11 2.6s linear infinite; animation-delay: 0.15s; }
    .s12 { animation: fall12 2.0s linear infinite; animation-delay: 0.55s; }
    .s13 { animation: fall13 2.3s linear infinite; animation-delay: 0.35s; }
    .s14 { animation: fall14 1.9s linear infinite; animation-delay: 0.75s; }
    .s15 { animation: fall15 2.5s linear infinite; animation-delay: 0.25s; }
    .s16 { animation: fall16 2.1s linear infinite; animation-delay: 0.65s; }
    .s17 { animation: fall17 1.8s linear infinite; animation-delay: 0.45s; }
    .s18 { animation: fall18 2.4s linear infinite; animation-delay: 0.85s; }
    .s19 { animation: fall19 2.2s linear infinite; animation-delay: 0.05s; }
    .s20 { animation: fall20 1.6s linear infinite; animation-delay: 0.95s; }
    .s21 { animation: fall21 2.8s linear infinite; animation-delay: 0.12s; }
    .s22 { animation: fall22 2.0s linear infinite; animation-delay: 0.52s; }
    .s23 { animation: fall23 1.9s linear infinite; animation-delay: 0.38s; }
    .s24 { animation: fall24 2.3s linear infinite; animation-delay: 0.72s; }
    .s25 { animation: fall25 2.1s linear infinite; animation-delay: 0.18s; }
    .s26 { animation: fall26 1.7s linear infinite; animation-delay: 0.62s; }
    .s27 { animation: fall27 2.5s linear infinite; animation-delay: 0.42s; }
    .s28 { animation: fall28 2.2s linear infinite; animation-delay: 0.82s; }
    .s29 { animation: fall29 1.8s linear infinite; animation-delay: 0.22s; }
    .s30 { animation: fall30 2.6s linear infinite; animation-delay: 0.92s; }

    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }
    .cursor { animation: blink 1s step-end infinite; fill: #00FF41; }
  </style>

