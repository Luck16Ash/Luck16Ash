<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 200" width="900" height="200">
  <rect width="900" height="200" fill="#000000"/>

  <style>
    .col { font-family: 'Courier New', monospace; font-size: 13px; fill: #00FF41; }
    .col-dim { font-family: 'Courier New', monospace; font-size: 13px; fill: #003300; }
    .col-mid { font-family: 'Courier New', monospace; font-size: 13px; fill: #00aa00; }
    .col-head { font-family: 'Courier New', monospace; font-size: 13px; fill: #ccffcc; }
    .title { font-family: 'Courier New', monospace; font-size: 26px; font-weight: bold; fill: #00FF41; letter-spacing: 3px; }
    .sub { font-family: 'Courier New', monospace; font-size: 12px; fill: #00C853; letter-spacing: 1px; }

    @keyframes fall1  { 0%{transform:translateY(-200px)} 100%{transform:translateY(220px)} }
    @keyframes fall2  { 0%{transform:translateY(-200px)} 100%{transform:translateY(220px)} }
    @keyframes fall3  { 0%{transform:translateY(-200px)} 100%{transform:translateY(220px)} }
